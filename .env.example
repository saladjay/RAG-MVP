# RAG Service MVP - Environment Variables

# Milvus Vector Database
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=knowledge_base
MILVUS_DIMENSION=384

# LiteLLM Configuration
LITELLM_API_KEY=your-api-key-here
LITELLM_API_BASE=https://api.openai.com/v1
LITELLM_MODEL=gpt-3.5-turbo
LITELLM_MAX_RETRIES=3
LITELLM_TIMEOUT=30

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=your-public-key-here
LANGFUSE_SECRET_KEY=your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_RELEASE=production

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# External HTTP Knowledge Base
EXTERNAL_KB_BASE_URL=http://128.23.77.226:6719
EXTERNAL_KB_ENDPOINT=/cloudoa-ai/ai/file-knowledge/queryKnowledge
EXTERNAL_KB_TIMEOUT=30
EXTERNAL_KB_MAX_RETRIES=3
EXTERNAL_KB_ENABLED=true

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=INFO

# CORS Configuration
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE
CORS_ALLOW_HEADERS=*

# Feature Flags
ENABLE_TRACING=true
ENABLE_METRICS=true
NON_BLOCKING_TRACING=true
