# RAG Service — Unified Environment Variables
# All config is organized in 5 sections. New deployments only need these.
# Old variable names (CLOUD_COMPLETION_*, GLM_*, QA_*, etc.) still work but are deprecated.

# ============================================================================
# 1. MILVUS — Vector Database
# ============================================================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=knowledge_base
MILVUS_DIMENSION=1024
MILVUS_DEFAULT_SEARCH_TYPE=hybrid
MILVUS_DEFAULT_LIMIT=10
MILVUS_CHUNK_SIZE=512
MILVUS_CHUNK_OVERLAP=50

# ============================================================================
# 2. LITELLM — Unified Inference Gateway
# ============================================================================
# Provider selection: openai (LiteLLM), cloud_http (HTTP Cloud), glm (GLM/BigModel)
LITELLM_PROVIDER=glm
LITELLM_MODEL=glm-4.5-air
LITELLM_API_KEY=
LITELLM_API_BASE=https://api.openai.com/v1
LITELLM_MAX_RETRIES=3
LITELLM_TIMEOUT=30
LITELLM_TEMPERATURE=0.7
LITELLM_MAX_TOKENS=4096

# Cloud Embedding (internal provider)
LITELLM_EMBEDDING_URL=
LITELLM_EMBEDDING_MODEL=bge-m3
LITELLM_EMBEDDING_TIMEOUT=30

# Cloud Rerank (internal provider)
LITELLM_RERANK_URL=
LITELLM_RERANK_MODEL=embed_rerank

# ============================================================================
# 3. QUERY — Query Pipeline, Quality, External KB, Sessions
# ============================================================================
# Strategy selection
QUERY_RETRIEVAL_BACKEND=external_kb
QUERY_QUALITY_MODE=basic

# Pipeline toggles
QUERY_ENABLE_QUERY_REWRITE=true
QUERY_ENABLE_HALLUCINATION_CHECK=true
QUERY_HALLUCINATION_THRESHOLD=0.7

# External KB (used when QUERY_RETRIEVAL_BACKEND=external_kb)
QUERY_EXTERNAL_KB_BASE_URL=http://128.23.77.226:6719
QUERY_EXTERNAL_KB_ENDPOINT=/cloudoa-ai/ai/file-knowledge/queryKnowledge
QUERY_EXTERNAL_KB_TIMEOUT=30
QUERY_EXTERNAL_KB_MAX_RETRIES=3

# Redis sessions (used by dimension_gather and conversational modes)
QUERY_REDIS_HOST=localhost
QUERY_REDIS_PORT=6379
QUERY_REDIS_DB=0
QUERY_REDIS_PASSWORD=
QUERY_REDIS_TTL=900

# ============================================================================
# 4. LANGFUSE — Observability
# ============================================================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_RELEASE=production

# ============================================================================
# 5. SERVER — HTTP Server, CORS, Feature Flags
# ============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1
SERVER_LOG_LEVEL=INFO
SERVER_CORS_ORIGINS=*
SERVER_ENABLE_TRACING=true
SERVER_ENABLE_METRICS=true

# ============================================================================
# DEPRECATED — Old variable names (still accepted, will log deprecation warnings)
# ============================================================================
# CLOUD_COMPLETION_URL=         → LITELLM_PROVIDER=cloud_http
# CLOUD_COMPLETION_MODEL=       → (configure via LITELLM_CLOUD_HTTP_* vars)
# CLOUD_EMBEDDING_URL=          → LITELLM_EMBEDDING_URL
# GLM_URL=, GLM_API_KEY=       → LITELLM_PROVIDER=glm
# GLM_MODEL=                    → LITELLM_MODEL
# DEFAULT_GATEWAY=              → LITELLM_PROVIDER
# EXTERNAL_KB_BASE_URL=         → QUERY_EXTERNAL_KB_BASE_URL
# QA_ENABLE_QUERY_REWRITE=      → QUERY_ENABLE_QUERY_REWRITE
# QUERY_QUALITY_REDIS_HOST=     → QUERY_REDIS_HOST
# CONVERSATIONAL_QUERY_REDIS_*= → QUERY_REDIS_*
# EMBEDDING_MODEL=              → MILVUS_EMBEDDING_MODEL
# HOST=, PORT=                  → SERVER_HOST, SERVER_PORT
# CORS_ORIGINS=                 → SERVER_CORS_ORIGINS
# ENABLE_TRACING=               → SERVER_ENABLE_TRACING
