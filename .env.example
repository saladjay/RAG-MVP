# RAG Service MVP - Environment Variables

# Milvus Vector Database
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=knowledge_base
MILVUS_DIMENSION=384

# Milvus Internal Knowledge Base (Hybrid Search with BM25)
MILVUS_KB_URI=http://localhost:19530
MILVUS_KB_COLLECTION_NAME=knowledge_base
MILVUS_KB_TIMEOUT=30
MILVUS_KB_EMBEDDING_DIMENSION=1024
MILVUS_KB_DEFAULT_SEARCH_TYPE=hybrid
MILVUS_KB_DEFAULT_LIMIT=10
MILVUS_KB_DEFAULT_CHUNK_SIZE=512
MILVUS_KB_DEFAULT_CHUNK_OVERLAP=50
MILVUS_KB_HYBRID_RANKER=RRF
MILVUS_KB_RRF_K=60

# LiteLLM Configuration
LITELLM_API_KEY=your-api-key-here
LITELLM_API_BASE=https://api.openai.com/v1
LITELLM_MODEL=gpt-3.5-turbo
LITELLM_MAX_RETRIES=3
LITELLM_TIMEOUT=30
LITELLM_CONFIG_PATH=litellm_config.yaml

# Default Model for LiteLLM Gateway
DEFAULT_MODEL=glm-4.5-air

# GLM (智谱AI) API Key for LiteLLM
GLM_API_KEY=your-glm-api-key-here

# Default Gateway Selection
# Options: litellm (推荐), http, glm
DEFAULT_GATEWAY=litellm

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=your-public-key-here
LANGFUSE_SECRET_KEY=your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_RELEASE=production

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# External HTTP Knowledge Base
EXTERNAL_KB_BASE_URL=http://128.23.77.226:6719
EXTERNAL_KB_ENDPOINT=/cloudoa-ai/ai/file-knowledge/queryKnowledge
EXTERNAL_KB_TIMEOUT=30
EXTERNAL_KB_MAX_RETRIES=3
EXTERNAL_KB_ENABLED=true

# External KB Authentication (choose one pattern)
# Pattern 1: Bearer token (recommended for standard OAuth2/JWT)
# EXTERNAL_KB_AUTH_TOKEN=your-bearer-token-here
#
# Pattern 2: Custom headers (most flexible - use for any auth pattern)
# For xtoken: EXTERNAL_KB_HEADERS={"xtoken": "your-token"}
# For API key: EXTERNAL_KB_HEADERS={"x-api-key": "your-api-key"}
# For custom auth: EXTERNAL_KB_HEADERS={"X-Custom-Auth": "value"}
#
# Pattern 3: Simple token (deprecated - use headers or auth_token instead)
# EXTERNAL_KB_TOKEN=12345fdsaga6

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=INFO

# CORS Configuration
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE
CORS_ALLOW_HEADERS=*

# Feature Flags
ENABLE_TRACING=true
ENABLE_METRICS=true
NON_BLOCKING_TRACING=true

# ============================================================================
# Cloud Services Configuration (HTTP Completion)
# ============================================================================

# Cloud Services Common Authentication
CLOUD_AUTH_TOKEN=T0EtZ3JvdXAtYXV0aDpPQS1ncm91cC1hdXRo

# Cloud Embedding Service
CLOUD_EMBEDDING_URL=http://128.23.74.3:9091/llm/embed-bge/v1/embeddings
CLOUD_EMBEDDING_MODEL=bge-m3
CLOUD_EMBEDDING_TIMEOUT=30

# Cloud Rerank Service
CLOUD_RERANK_URL=http://128.23.74.3:9091/llm/embed-reranker/rerank
CLOUD_RERANK_MODEL=embed_rerank
CLOUD_RERANK_TIMEOUT=30

# Cloud Completion Service (Direct HTTP API)
CLOUD_COMPLETION_URL=http://128.23.74.3:9091/llm/Qwen3-32B-Instruct/v1/completions
CLOUD_COMPLETION_MODEL=Qwen3-32B
CLOUD_COMPLETION_TIMEOUT=60
CLOUD_COMPLETION_MAX_RETRIES=3
CLOUD_COMPLETION_RETRY_DELAY=1.0

# Note: Use CLOUD_COMPLETION_* settings for direct HTTP API calls
#       Use LITELLM_* settings for LiteLLM multi-provider access
#       Set gateway_backend="http" in ModelInferenceInput to use cloud completion

# ============================================================================
# GLM (智谱AI BigModel) Configuration
# ============================================================================

# GLM API Configuration
GLM_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_MODEL=glm-4.5-air
GLM_API_KEY=your-glm-api-key-here
GLM_TIMEOUT=120
GLM_MAX_RETRIES=3
GLM_RETRY_DELAY=1.0
GLM_ENABLE_THINKING=false

# GLM Model Options:
# - glm-4.5: Latest flagship model, best performance
# - glm-4.5-air: Cost-effective model for most tasks (recommended)
# - glm-4-flash: Fast and lightweight model for simple tasks

# Usage: Set gateway_backend="glm" in ModelInferenceInput to use GLM
# API Reference: https://open.bigmodel.cn/api/paas/v4/chat/completions
